# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# OpenRouter (рекомендуется) или OpenAI
OPENROUTER_API_KEY=your_openrouter_api_key
# При OpenRouter по умолчанию: google/gemini-3-flash-preview (high effort thinking)
LLM_MODEL=google/gemini-3-flash-preview   # можно переопределить

# Notion (только для Notion агента)
NOTION_API_KEY=your_notion_integration_token

# Firebase (Analytics Agent)
FIREBASE_CREDENTIALS_PATH=firebase-key.json
# BigQuery dataset для Firebase Analytics (включи экспорт в Firebase Console)
# Формат: analytics_XXXXX (property ID из Firebase/GA4)
FIREBASE_ANALYTICS_DATASET=analytics_123456789

# Adapty (монетизация)
ADAPTY_SECRET_KEY=your_adapty_secret_key

# Опционально: для push в GitHub (Coding агент)
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPO=username/repo-name
