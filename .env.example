# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# OpenRouter (рекомендуется) или OpenAI
OPENROUTER_API_KEY=your_openrouter_api_key
# При OpenRouter по умолчанию: google/gemini-3-flash-preview
LLM_MODEL=google/gemini-3-flash-preview   # можно переопределить (напр. z-ai/glm-5)
# Голосовые сообщения всегда транскрибируются через openai/gpt-audio-mini (тот же OpenRouter)

# Сила «думания» модели (OpenRouter Gemini): low, medium, high; также minimal, xhigh, none
THINKING_EFFORT=high

# Notion (только для Notion агента)
NOTION_API_KEY=your_notion_integration_token

# GA4 (Analytics Agent)
# Локально: путь к JSON ключа. На деплое (Railway и др.): полный JSON в переменной ниже.
GOOGLE_CREDENTIALS_PATH=ga4-key.json   # путь к service account JSON (локально)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}  # для деплоя — весь JSON одной строкой
GA4_PROPERTY_ID=123456789              # GA4 Property ID (только цифры)

# Adapty (монетизация)
ADAPTY_SECRET_KEY=your_adapty_secret_key

# Опционально: для push в GitHub (Coding агент)
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPO=username/repo-name
